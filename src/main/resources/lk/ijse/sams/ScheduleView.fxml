<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.sams.controller.ScheduleController"
            style="-fx-background-color: #f8f5fe;">

    <VBox spacing="15" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0c8f0; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Class Schedule Management" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>

            <GridPane hgap="15" vgap="10">
                <Label text="Course:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <ComboBox fx:id="cmbCourse" promptText="Select course"
                          GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>

                <Label text="Subject:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <ComboBox fx:id="cmbSubject" promptText="Select subject"
                          GridPane.rowIndex="0" GridPane.columnIndex="3" prefWidth="200"/>

                <Label text="Lecturer:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <ComboBox fx:id="cmbLecturer" promptText="Select lecturer"
                          GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>

                <Label text="Date:" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <DatePicker fx:id="dpDate" GridPane.rowIndex="1" GridPane.columnIndex="3" prefWidth="200"/>

                <Label text="Start Time:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <TextField fx:id="txtStartTime" promptText="e.g. 09:00"
                           GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="200"
                           style="-fx-border-color: #e0c8f0; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 7;"/>

                <Label text="End Time:" GridPane.rowIndex="2" GridPane.columnIndex="2" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <TextField fx:id="txtEndTime" promptText="e.g. 11:00"
                           GridPane.rowIndex="2" GridPane.columnIndex="3" prefWidth="200"
                           style="-fx-border-color: #e0c8f0; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 7;"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Add" onAction="#handleAdd"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Delete" onAction="#handleDelete"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Clear" onAction="#handleClear"
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <VBox spacing="8" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0c8f0; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Schedule List" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
            <TableView fx:id="tblSchedule" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colCourse" text="Course" prefWidth="150"/>
                    <TableColumn fx:id="colSubject" text="Subject" prefWidth="150"/>
                    <TableColumn fx:id="colLecturer" text="Lecturer" prefWidth="150"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                    <TableColumn fx:id="colStart" text="Start" prefWidth="80"/>
                    <TableColumn fx:id="colEnd" text="End" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</AnchorPane>
