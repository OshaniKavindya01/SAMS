<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="lk.ijse.sams.controller.LecturerAttendanceController"
            style="-fx-background-color: #f8f5fe;">

    <VBox spacing="15" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox spacing="12"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0c8f0; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Mark Attendance"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Select Session:" style="-fx-text-fill: #555; -fx-font-size: 13;"/>
                <ComboBox fx:id="cmbSession" promptText="Select your class session" prefWidth="350"/>
                <Button text="Load Students" onAction="#handleLoadStudents"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Button text="Save Attendance" onAction="#handleSave"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <VBox spacing="8" VBox.vgrow="ALWAYS"
              style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0c8f0; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Students"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
            <TableView fx:id="tblAttendance" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colStudentId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="200"/>
                    <TableColumn fx:id="colRegNo" text="Reg Number" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</AnchorPane>
